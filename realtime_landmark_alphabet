import json
import pickle
from collections import Counter, deque
from pathlib import Path

import cv2
import mediapipe as mp
import numpy as np
import pandas as pd

BASE_DIR = Path(__file__).resolve().parent.parent
MODEL_PATH = BASE_DIR / "models" / "alphabet_landmark_model.pkl"
LABELS_PATH = BASE_DIR / "models" / "alphabet_landmark_labels.json"

with open(MODEL_PATH, "rb") as f:
    model = pickle.load(f)

with open(LABELS_PATH, "r", encoding="utf-8") as f:
    class_names = json.load(f)

mp_hands = mp.solutions.hands
mp_draw = mp.solutions.drawing_utils

hands = mp_hands.Hands(
    static_image_mode=False,
    max_num_hands=1,
    min_detection_confidence=0.4,
    min_tracking_confidence=0.4
)

cap = cv2.VideoCapture(0, cv2.CAP_DSHOW)

if not cap.isOpened():
    raise RuntimeError("Could not open webcam.")

feature_names = []
for hand_num in range(2):
    for point_num in range(21):
        feature_names.extend([
            f"h{hand_num+1}_x{point_num}",
            f"h{hand_num+1}_y{point_num}",
            f"h{hand_num+1}_z{point_num}"
        ])

prediction_buffer = deque(maxlen=5)
display_label = "No hand detected"
confidence = 0.0

while True:
    ret, frame = cap.read()
    if not ret:
        break

    frame = cv2.flip(frame, 1)
    rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
    results = hands.process(rgb)

    if results.multi_hand_landmarks:
        hand_landmarks = results.multi_hand_landmarks[0]
        mp_draw.draw_landmarks(frame, hand_landmarks, mp_hands.HAND_CONNECTIONS)

        landmarks_row = []

        for lm in hand_landmarks.landmark:
            landmarks_row.extend([lm.x, lm.y, lm.z])

        while len(landmarks_row) < 126:
            landmarks_row.extend([0.0, 0.0, 0.0])

        input_df = pd.DataFrame([landmarks_row], columns=feature_names)

        probs = model.predict_proba(input_df)[0]
        pred_index = int(np.argmax(probs))
        confidence = float(np.max(probs))
        predicted_label = class_names[pred_index]

        prediction_buffer.append(predicted_label)
        most_common_label, count = Counter(prediction_buffer).most_common(1)[0]

        if confidence >= 0.35 or count >= 3:
            display_label = most_common_label
        else:
            display_label = predicted_label
    else:
        display_label = "No hand detected"
        confidence = 0.0
        prediction_buffer.clear()

    cv2.putText(frame, f"Prediction: {display_label}", (10, 40),
                cv2.FONT_HERSHEY_SIMPLEX, 1, (0, 255, 0), 2)

    cv2.putText(frame, f"Confidence: {confidence:.2f}", (10, 80),
                cv2.FONT_HERSHEY_SIMPLEX, 0.8, (0, 255, 255), 2)

    cv2.putText(frame, "Press Q to quit", (10, 120),
                cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 255, 255), 2)

    cv2.imshow("Landmark Alphabet Recognition", frame)

    if cv2.waitKey(1) & 0xFF == ord("q"):
        break

cap.release()
hands.close()
cv2.destroyAllWindows()
